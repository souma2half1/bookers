<body>
<p id="notice"></p>
<h1>Books</h1>

<table width=400px>
    <thead>
    <th>table</th>
    <th>body</th>
    </thead>
    <tbody>
       <% @books.each do|book| %>
        <tr>
            <td><%= book.title %></td>
            <td><%= book.body %></td>
            <td><%=link_to"Show",book_path(book.id)%></td>
            <td><%=link_to"Edit",edit_book_path(book.id)%></td>
            <td><%=link_to"Destroy",book_path(book.id),method: :delete,"data-confirm"=>"本当に削除しますか？"%></td>
        </tr>
        <%end%>
    </tbody>
</table>


   

<h2>New book</h2>
<% if @book.errors.any? %>
 <%= @book.errors.count %>error.can't be blank.show back.
 
<%end%>

<%=form_with model:@book do|f| %>
 <h3>title</h3>
 <%=f.text_field:title%>
 
 <h4>Body</h4>
 <%=f.text_area :body %>
 
 <%=f.submit'Create Books'%>
<%end%>

