<h1>Editing Book</h1>

<%=form_with model:@book do |f|%>

<h2>Title</h2>
<%= f.text_field:title %>

<h3>Body</h3>
<%= f.text_area:body %>
<%=f.submit'Update Book'%>

<%end%>

<% if @book.errors.any? %>
 <%= @book.errors.count %>error


<%end%>

<%= link_to"show",book_path(@book.id) %>
<%= link_to"back",books_path %>